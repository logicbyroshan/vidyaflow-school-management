{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django: Backend",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/apps/backend/manage.py",
      "args": ["runserver", "0.0.0.0:8000"],
      "django": true,
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings.development"
      },
      "cwd": "${workspaceFolder}/apps/backend"
    },
    {
      "name": "Web: Vite Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev", "--filter=@vidyaflow/web"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Desktop: Electron",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev", "--filter=@vidyaflow/desktop"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Pytest: Backend",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": ["--no-header", "-rN"],
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings.testing"
      },
      "cwd": "${workspaceFolder}/apps/backend",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Backend + Web",
      "configurations": ["Django: Backend", "Web: Vite Dev Server"]
    }
  ]
}
