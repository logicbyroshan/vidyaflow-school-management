{
  "name": "@vidyaflow/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "lint": "eslint . --ext ts,tsx",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "rimraf .expo node_modules/.cache .turbo"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-navigation/native": "^6.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@vidyaflow/api": "workspace:*",
    "@vidyaflow/constants": "workspace:*",
    "@vidyaflow/types": "workspace:*",
    "@vidyaflow/utils": "workspace:*",
    "@vidyaflow/validation": "workspace:*",
    "expo": "~52.0.0",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.0",
    "react-hook-form": "^7.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.3.0",
    "@types/react-native": "~0.76.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0"
  }
}
