{
  "name": "@vidyaflow/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "tsc -b && vite build && electron-builder build",
    "lint": "eslint . --ext ts,tsx",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist out .turbo"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@vidyaflow/api": "workspace:*",
    "@vidyaflow/hooks": "workspace:*",
    "@vidyaflow/types": "workspace:*",
    "@vidyaflow/ui": "workspace:*",
    "@vidyaflow/utils": "workspace:*",
    "electron-updater": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^2.0.0"
  }
}
