# VidyaFlow — Environment Configuration Example
# Copy this file to .env and fill in the values for your environment.

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-strong-secret-key

# ─── Backend (Django) ─────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-strong-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vidyaflow:password@localhost:5432/vidyaflow_db
POSTGRES_DB=vidyaflow_db
POSTGRES_USER=vidyaflow
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Frontend (Web) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development

# ─── Storage ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=vidyaflow-media
AWS_S3_REGION_NAME=us-east-1

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@vidyaflow.com
EMAIL_HOST_PASSWORD=your-email-password

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_AI_ASSISTANT=false
FEATURE_WHATSAPP_INTEGRATION=false
FEATURE_BIOMETRIC=false
